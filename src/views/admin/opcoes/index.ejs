<%- include('../partials/header', { pageTitle: 'Opções do Bot' }) %>

  <!-- HEADER -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Opções do Bot</h2>
  </div>

  <!-- BOTÃO NOVO -->
  <div class="mb-3">
    <a href="/admin/opcoes/nova" class="btn btn-primary">
      Nova opção
    </a>
  </div>

  <!-- TABELA -->
  <table class="table table-bordered table-striped bg-white">
    <thead>
      <tr>
        <th>ID</th>
        <th>Código</th>
        <th>Nome</th>
        <th>Ativo</th>
        <th>Ações</th>
      </tr>
    </thead>

    <tbody>
      <% if (opcoes.length === 0) { %>
        <tr>
          <td colspan="5" class="text-center text-muted">
            Nenhuma opção cadastrada
          </td>
        </tr>
      <% } %>

      <% opcoes.forEach(function(opcao) { %>
        <tr>
          <td><%= opcao.id %></td>
          <td><%= opcao.codigo %></td>
          <td><%= opcao.nome %></td>

          <td>
            <% if (opcao.ativo === 'S') { %>
              <span class="badge bg-success">Ativo</span>
            <% } else { %>
              <span class="badge bg-danger">Inativo</span>
            <% } %>
          </td>

          <td>
            <a href="/admin/opcoes/<%= opcao.id %>/editar"
               class="btn btn-sm btn-warning">
              Editar
            </a>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>


  <%- include('../partials/footer') %>