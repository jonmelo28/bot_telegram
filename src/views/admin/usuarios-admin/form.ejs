<%- include('../partials/header', { pageTitle: usuarioAdmin ? 'Editar Usuário Admin' : 'Novo Usuário Admin' }) %>

<div class="container py-4">
  <div class="mb-4">
    <h2 class="fw-bold mb-1"><%= usuarioAdmin ? 'Editar Usuário Admin' : 'Novo Usuário Admin' %></h2>
    <p class="text-muted mb-0">Preencha os dados do usuário administrador.</p>
  </div>

  <% if (erro) { %>
    <div class="alert alert-danger"><%= erro %></div>
  <% } %>

  <div class="card shadow-sm border-0">
    <div class="card-body">
      <form method="POST" action="/admin/usuarios-admin/salvar" class="row g-3">
        <input type="hidden" name="id" value="<%= usuarioAdmin?.id || '' %>">

        <div class="col-md-6">
          <label class="form-label fw-semibold">Nome</label>
          <input
            type="text"
            class="form-control"
            name="nome"
            value="<%= usuarioAdmin?.nome || '' %>"
            required
          >
        </div>

        <div class="col-md-6">
          <label class="form-label fw-semibold">E-mail</label>
          <input
            type="email"
            class="form-control"
            name="email"
            value="<%= usuarioAdmin?.email || '' %>"
            required
          >
        </div>

        <div class="col-md-6">
          <label class="form-label fw-semibold">
            Senha
            <% if (usuarioAdmin) { %>
              <small class="text-muted">(preencha apenas se quiser alterar)</small>
            <% } %>
          </label>
          <input
            type="password"
            class="form-control"
            name="senha"
            <%= usuarioAdmin ? '' : 'required' %>
          >
        </div>

        <div class="col-md-3">
          <label class="form-label fw-semibold">Status</label>
          <select class="form-select" name="status">
            <option value="1" <%= String(usuarioAdmin?.status ?? '1') === '1' ? 'selected' : '' %>>Ativo</option>
            <option value="0" <%= String(usuarioAdmin?.status ?? '1') === '0' ? 'selected' : '' %>>Inativo</option>
          </select>
        </div>

        <div class="col-12 d-flex gap-2 mt-4">
          <button type="submit" class="btn btn-primary">
            Salvar
          </button>
          <a href="/admin/usuarios-admin" class="btn btn-outline-secondary">
            Voltar
          </a>
        </div>
      </form>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>