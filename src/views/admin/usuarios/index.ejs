<%- include('../partials/header', { pageTitle: 'Usuários do Bot' }) %>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Usuários do Bot</h2>
  </div>

  <div class="mb-3">
    <a href="/admin/usuarios/novo" class="btn btn-primary">Novo usuário</a>
  </div>

  <table class="table table-bordered table-striped bg-white">
    <thead>
      <tr>
        <th>ID</th>
        <th>Nome</th>
        <th>Telegram ID</th>
        <th>Codusur</th>
        <th>Codsuperv</th>
        <th>perfil</th>
        <th>Ativo</th>
        <th>Ações</th>
      </tr>
    </thead>

    <tbody>
      <% if (usuarios.length === 0) { %>
        <tr>
          <td colspan="7" class="text-center text-muted">
            Nenhum usuário cadastrado
          </td>
        </tr>
      <% } %>

      <% usuarios.forEach(function(usuario) { %>
        <tr>
          <td><%= usuario.id %></td>
          <td><%= usuario.nome %></td>
          <td><%= usuario.telegram_user_id %></td>
          <td><%= usuario.codusur || '' %></td>
          <td><%= usuario.codsupervisor || '' %></td>
          <td><%= usuario.perfil || '' %></td>
          
          <td>
            <% if (usuario.ativo === 'S') { %>
              <span class="badge bg-success">Ativo</span>
            <% } else { %>
              <span class="badge bg-danger">Inativo</span>
            <% } %>
          </td>

          <td>
            <a href="/admin/usuarios/<%= usuario.id %>/editar" class="btn btn-sm btn-warning">
              Editar
            </a>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>

  <%- include('../partials/footer') %>