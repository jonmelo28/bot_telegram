<%- include('../partials/header', { pageTitle: usuario ? 'Editar usuário' : 'Novo usuário' }) %>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">
      <%= usuario ? 'Editar usuário' : 'Novo usuário' %>
    </h2>
  </div>

  <form method="POST" action="/admin/usuarios/salvar" class="card shadow-sm border-0">
    <div class="card-body">

      <input type="hidden" name="id" value="<%= usuario?.id || '' %>">

      <div class="row g-3">

        <div class="col-md-4">
          <label class="form-label">Telegram User ID</label>
          <input type="text" class="form-control" name="telegram_user_id"
            value="<%= usuario?.telegram_user_id || '' %>" required>
        </div>

        <div class="col-md-4">
          <label class="form-label">Telegram Chat ID</label>
          <input type="text" class="form-control" name="telegram_chat_id"
            value="<%= usuario?.telegram_chat_id || '' %>">
        </div>

        <div class="col-md-4">
          <label class="form-label">Nome</label>
          <input type="text" class="form-control" name="nome"
            value="<%= usuario?.nome || '' %>" required>
        </div>

        <div class="col-md-3">
          <label class="form-label">Codusur</label>
          <input type="number" class="form-control" name="codusur"
            value="<%= usuario?.codusur || '' %>">
        </div>

        <div class="col-md-3">
          <label class="form-label">Codsupervisor</label>
          <input type="number" class="form-control" name="codsupervisor"
            value="<%= usuario?.codsupervisor || '' %>">
        </div>

        <div class="col-md-3">
          <label class="form-label">Status</label>
          <select class="form-select" name="ativo">
            <option value="S" <%= usuario?.ativo === 'S' || !usuario ? 'selected' : '' %>>Ativo</option>
            <option value="N" <%= usuario?.ativo === 'N' ? 'selected' : '' %>>Inativo</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label">Perfil</label>
          <select class="form-select" name="perfil">
            <option value="VENDEDOR" <%= usuario?.perfil === 'VENDEDOR' ? 'selected' : '' %>>VENDEDOR</option>
            <option value="SUPERVISOR" <%= usuario?.perfil === 'SUPERVISOR' ? 'selected' : '' %>>SUPERVISOR</option>
            <option value="FORNECEDOR" <%= usuario?.perfil === 'FORNECEDOR' ? 'selected' : '' %>>FORNECEDOR</option>
            <option value="DEPOSITO" <%= usuario?.perfil === 'DEPOSITO' ? 'selected' : '' %>>DEPOSITO</option>
          </select>
        </div>

      </div>

    </div>

    <div class="card-footer bg-white text-end">
      <button class="btn btn-success" type="submit">Salvar</button>
      <a href="/admin/usuarios" class="btn btn-outline-secondary">Cancelar</a>
    </div>

  </form>

    <%- include('../partials/footer') %>
