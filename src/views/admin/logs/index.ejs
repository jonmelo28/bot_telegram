<%- include('../partials/header', { pageTitle: 'Logs Administrativos' }) %>

<h2 class="mb-4">Logs Administrativos</h2>

<table class="table table-bordered table-striped bg-white">
  <thead>
    <tr>
      <th>ID</th>
      <th>Admin</th>
      <th>Ação</th>
      <th>Tabela</th>
      <th>Registro</th>
      <th>Descrição</th>
      <th>Data</th>
    </tr>
  </thead>
  <tbody>
    <% if (logs.length === 0) { %>
      <tr>
        <td colspan="7" class="text-center text-muted">Nenhum log encontrado</td>
      </tr>
    <% } %>

    <% logs.forEach(function(log) { %>
      <tr>
        <td><%= log.id %></td>
        <td><%= log.admin_nome || '' %></td>
        <td><%= log.acao %></td>
        <td><%= log.tabela_afetada %></td>
        <td><%= log.registro_id || '' %></td>
        <td><%= log.descricao || '' %></td>
        <td><%= log.dt_log_formatado %></td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include('../partials/footer') %>